# LLM Provider Configuration
# TraceGen supports any OpenAI-compatible API endpoint

# Primary LLM API Key (for synthesis and analysis)
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1

# Embedding API Key (for vector similarity search)
# Can be the same as LLM_API_KEY if using the same provider
EMBEDDING_API_KEY=sk-your-embedding-api-key-here
